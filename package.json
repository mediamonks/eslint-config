{
  "name": "@mediamonks/eslint-config-root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "author": "frontend.monks",
  "type": "module",
  "scripts": {
    "eslint": "npx eslint .",
    "eslint:fix": "npx eslint:fix .",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write \"./**/*.{ts,js,tsx,jsx,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@mediamonks/eslint-config": "^2.5.0",
    "@mediamonks/prettier-config": "^1.0.1",
    "eslint": "^9.3.0",
    "husky": "^9.0.10",
    "lerna": "^8.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "prettier": "@mediamonks/prettier-config",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json}": "prettier --write"
  }
}
